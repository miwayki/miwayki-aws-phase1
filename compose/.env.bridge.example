CHATWOOT_BASE_URL=http://chatwoot:3000
CHATWOOT_API_TOKEN=replace_with_chatwoot_api_access_token
BRIDGE_AUTO_REPLY=Recibido. Este es el bridge MVP de prueba conectado correctamente.
# Opcional en dev; en prod: copiar el secret del webhook en Chatwoot (Integraciones → Webhooks).
CHATWOOT_WEBHOOK_SECRET=

# Langflow (Chatflow publicado): API de servicio. Desde el contenedor bridge usar el host Docker "langflow", no 127.0.0.1.
LANGFLOW_API_BASE=http://langflow:7860/api/v1
LANGFLOW_FLOW_ID=replace_with_langflow_flow_id
LANGFLOW_API_KEY=replace_with_langflow_app_secret_key

# Sincronización de atributos (Lead Scoring, Temperatura, Resumen). 
# Habilita la visibilidad de datos de la IA en el panel lateral de Chatwoot.
# Por defecto desactivado (0); activar con 1. 
# Requiere que el Chatflow de Langflow esté configurado para devolver JSON (§12.3).
BRIDGE_SYNC_CHATWOOT_ATTRIBUTES=0

# ── NocoDB adapter (Fase 2 — Catálogo comercial) ──────────────────
NOCODB_BASE_URL=http://nocodb:8080
NOCODB_API_TOKEN=replace_after_nocodb_setup
NOCODB_TABLE_ID_TOURS=replace
NOCODB_TABLE_ID_VARIANTS=replace
NOCODB_TABLE_ID_SEASONS=replace
NOCODB_TABLE_ID_HOLIDAYS=replace
NOCODB_TABLE_ID_PRICING_RULES=replace
NOCODB_TABLE_ID_BANK_ACCOUNTS=replace
NOCODB_TABLE_ID_EXCEPTIONS=replace

# ── PostgreSQL Bridge (Fase 2 — persistencia leads/quotes/reservas)
BRIDGE_DATABASE_URL=postgresql://miwayki_app:change_me_strong_password@postgres:5432/miwayki

# ── Handoff thresholds ────────────────────────────────────────────
HANDOFF_MAX_GROUP_SIZE=15
HANDOFF_MAX_FUTURE_MONTHS=18
HANDOFF_SCORE_THRESHOLD=70
