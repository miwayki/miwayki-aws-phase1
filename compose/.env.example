POSTGRES_DB=miwayki
POSTGRES_USER=miwayki_app
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_PORT=5432

REDIS_PORT=6379

# Puerto en tu Mac/VM donde escucha el bridge (mapeo host→contenedor). El contenedor sigue usando 8000 por dentro.
# Cambia si otro proyecto ya usa 8000 en localhost (ej. 18000).
BRIDGE_HOST_PORT=8000

# ── NocoDB (Catálogo comercial — Fase 2) ──────────────────────────
NOCODB_PORT=8090
NOCODB_PG_PASSWORD=change_me_nocodb_password
NOCODB_JWT_SECRET=generate_with_openssl_rand_hex_32
